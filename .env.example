# API base URL
# Leave empty to use Next.js mock route handlers on same origin (dev + Vercel preview)
# Set to real backend URL for production: https://api.your-backend.com
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_FEATURE_DIGITAL_TWIN=false → true
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_ENV=development

# JWT signing secret — MUST be set in production (min 32 chars, random)
# Generate: openssl rand -base64 32
# Note: e2e tests set this automatically via playwright.config.ts webServer.env
JWT_SECRET=
